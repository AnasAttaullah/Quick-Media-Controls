<Page
    x:Class="Quick_Media_Controls.Views.Pages.KeybindsSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Quick_Media_Controls.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Quick_Media_Controls.Models"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Keybinds Setting Window"
    mc:Ignorable="d">

    <StackPanel Margin="14">

        <ui:TextBlock
            FontSize="22"
            FontTypography="Subtitle"
            Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
            Text="Keybinds Settings" />

        <!--  Keyboard Keybinds Settings  -->
        <ui:TextBlock
            Margin="0,10"
            Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
            Text="Keyboard Shortcuts" />

        <ui:CardControl
            Margin="0,0,0,4"
            Padding="20,15,20,15"
            Icon="{ui:SymbolIcon Symbol=Play20}">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        Text="Play / Pause"
                        TextWrapping="WrapWithOverflow" />
                </StackPanel>
            </ui:CardControl.Header>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:TextBox
                    x:Name="PlayPauseHotkeyTextBox"
                    Grid.Column="0"
                    Width="200"
                    Margin="0,0,8,0"
                    IsReadOnly="True" />

                <ui:Button
                    Grid.Column="1"
                    Click="ResetPlayPauseButton_Click"
                    Content="Reset" />
            </Grid>
        </ui:CardControl>

        <ui:CardControl
            Margin="0,0,0,4"
            Padding="20,15,20,15"
            Icon="{ui:SymbolIcon Symbol=Next20}">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        Text="Next track"
                        TextWrapping="WrapWithOverflow" />
                </StackPanel>
            </ui:CardControl.Header>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:TextBox
                    x:Name="NextTrackHotkeyTextBox"
                    Grid.Column="0"
                    Width="200"
                    Margin="0,0,8,0"
                    IsReadOnly="True" />

                <ui:Button
                    Grid.Column="1"
                    Click="ResetNextTrackButton_Click"
                    Content="Reset" />
            </Grid>
        </ui:CardControl>

        <ui:CardControl
            Margin="0,0,0,4"
            Padding="20,15,20,15"
            Icon="{ui:SymbolIcon Symbol=Previous20}">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        Text="Previous track"
                        TextWrapping="WrapWithOverflow" />
                </StackPanel>
            </ui:CardControl.Header>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:TextBox
                    x:Name="PreviousTrackHotkeyTextBox"
                    Grid.Column="0"
                    Width="200"
                    Margin="0,0,8,0"
                    IsReadOnly="True" />

                <ui:Button
                    Grid.Column="1"
                    Click="ResetPreviousTrackButton_Click"
                    Content="Reset" />
            </Grid>
        </ui:CardControl>

        <ui:CardControl
            Margin="0,0,0,0"
            Padding="20,15,20,15"
            Icon="{ui:SymbolIcon Symbol=Window20}">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        Text="Open flyout"
                        TextWrapping="WrapWithOverflow" />
                </StackPanel>
            </ui:CardControl.Header>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:TextBox
                    x:Name="OpenFlyoutHotkeyTextBox"
                    Grid.Column="0"
                    Width="200"
                    Margin="0,0,8,0"
                    IsReadOnly="True" />

                <ui:Button
                    Grid.Column="1"
                    Click="ResetOpenFlyoutButton_Click"
                    Content="Reset" />
            </Grid>
        </ui:CardControl>

        <ui:TextBlock
            x:Name="HotkeyValidationTextBlock"
            Margin="0,4,0,0"
            FontTypography="Caption"
            Foreground="{ui:ThemeResource SystemFillColorCautionBrush}"
            Visibility="Collapsed" />

        <!--  Mouse Keybinds Settings  -->
        <Grid Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ui:TextBlock
                Margin="0,10"
                Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                Text="Mouse Shortcuts" />

            <ui:Button
                Name="ResetMouseShortcutsButton"
                Grid.Column="1"
                Margin="0,2,0,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Appearance="Transparent"
                BorderBrush="Transparent"
                Click="ResetMouseShortcutsButton_Click"
                Content="Reset"
                Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                Icon="{ui:SymbolIcon Symbol=ArrowCounterclockwise16}" />
        </Grid>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ui:CardControl
                Grid.Column="0"
                Height="auto"
                Margin="0,0,2,0"
                Padding="20,25,20,25">
                <ui:CardControl.Header>
                    <StackPanel>

                        <ui:SymbolIcon
                            FontSize="92"
                            Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                            Symbol="CursorClick24" />
                        <ui:TextBlock
                            Margin="0,10,0,0"
                            FontSize="18"
                            FontTypography="Subtitle"
                            Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                            Text="Mouse Click Actions"
                            TextAlignment="Center"
                            TextWrapping="WrapWithOverflow" />
                        <ui:TextBlock
                            Margin="0,4,0,0"
                            FontSize="12"
                            FontTypography="Body"
                            Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                            Text="Each mouse click must be assigned a unique action"
                            TextAlignment="Center"
                            TextWrapping="WrapWithOverflow" />
                    </StackPanel>
                </ui:CardControl.Header>
            </ui:CardControl>

            <StackPanel Grid.Column="1" Margin="2,0,0,0">
                <ui:CardControl Padding="12,10">
                    <ui:CardControl.Header>
                        <ui:TextBlock
                            Grid.Column="0"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                            Text="Single Left Click" />

                    </ui:CardControl.Header>
                    <ComboBox
                        x:Name="LeftClickActionComboBox"
                        Grid.Column="1"
                        Width="140"
                        SelectionChanged="MouseShortcutComboBox_SelectionChanged">
                        <ComboBoxItem Content="None" Tag="{x:Null}" />
                        <ComboBoxItem Content="Play/Pause" Tag="{x:Static models:ShortcutAction.PlayPause}" />
                        <ComboBoxItem Content="Next Track" Tag="{x:Static models:ShortcutAction.NextTrack}" />
                        <ComboBoxItem Content="Previous Track" Tag="{x:Static models:ShortcutAction.PreviousTrack}" />
                        <ComboBoxItem Content="Open Flyout" Tag="{x:Static models:ShortcutAction.OpenFlyout}" />
                    </ComboBox>
                </ui:CardControl>

                <ui:CardControl Padding="12,10">
                    <ui:CardControl.Header>
                        <ui:TextBlock
                            Grid.Column="0"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                            Text="Double Left Click" />

                    </ui:CardControl.Header>
                    <ComboBox
                        x:Name="DoubleLeftClickActionComboBox"
                        Grid.Column="1"
                        Width="140"
                        SelectionChanged="MouseShortcutComboBox_SelectionChanged">
                        <ComboBoxItem Content="None" Tag="{x:Null}" />
                        <ComboBoxItem Content="Play/Pause" Tag="{x:Static models:ShortcutAction.PlayPause}" />
                        <ComboBoxItem Content="Next Track" Tag="{x:Static models:ShortcutAction.NextTrack}" />
                        <ComboBoxItem Content="Previous Track" Tag="{x:Static models:ShortcutAction.PreviousTrack}" />
                        <ComboBoxItem Content="Open Flyout" Tag="{x:Static models:ShortcutAction.OpenFlyout}" />
                    </ComboBox>
                </ui:CardControl>

                <ui:CardControl Padding="12,10">
                    <ui:CardControl.Header>
                        <ui:TextBlock
                            Grid.Column="0"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                            Text="Right Click" />

                    </ui:CardControl.Header>
                    <ComboBox
                        x:Name="RightClickActionComboBox"
                        Grid.Column="1"
                        Width="140"
                        SelectionChanged="MouseShortcutComboBox_SelectionChanged">
                        <ComboBoxItem Content="None" Tag="{x:Null}" />
                        <ComboBoxItem Content="Play/Pause" Tag="{x:Static models:ShortcutAction.PlayPause}" />
                        <ComboBoxItem Content="Next Track" Tag="{x:Static models:ShortcutAction.NextTrack}" />
                        <ComboBoxItem Content="Previous Track" Tag="{x:Static models:ShortcutAction.PreviousTrack}" />
                        <ComboBoxItem Content="Open Flyout" Tag="{x:Static models:ShortcutAction.OpenFlyout}" />
                    </ComboBox>
                </ui:CardControl>

                <ui:CardControl Padding="12,10">
                    <ui:CardControl.Header>
                        <ui:TextBlock
                            Grid.Column="0"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                            Text="Middle Click" />

                    </ui:CardControl.Header>
                    <ComboBox
                        x:Name="MiddleClickActionComboBox"
                        Grid.Column="1"
                        Width="140"
                        SelectionChanged="MouseShortcutComboBox_SelectionChanged">
                        <ComboBoxItem Content="None" Tag="{x:Null}" />
                        <ComboBoxItem Content="Play/Pause" Tag="{x:Static models:ShortcutAction.PlayPause}" />
                        <ComboBoxItem Content="Next Track" Tag="{x:Static models:ShortcutAction.NextTrack}" />
                        <ComboBoxItem Content="Previous Track" Tag="{x:Static models:ShortcutAction.PreviousTrack}" />
                        <ComboBoxItem Content="Open Flyout" Tag="{x:Static models:ShortcutAction.OpenFlyout}" />
                    </ComboBox>
                </ui:CardControl>
            </StackPanel>
        </Grid>

        <ui:TextBlock
            x:Name="MouseShortcutValidationTextBlock"
            Margin="0,4,0,0"
            FontTypography="Caption"
            Foreground="{ui:ThemeResource SystemFillColorCautionBrush}"
            Visibility="Collapsed" />
    </StackPanel>
</Page>