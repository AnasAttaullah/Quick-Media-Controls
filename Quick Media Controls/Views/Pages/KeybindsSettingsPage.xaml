<Page
    x:Class="Quick_Media_Controls.Views.Pages.KeybindsSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Quick_Media_Controls.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Keybinds Setting Window"
    mc:Ignorable="d">

    <StackPanel Margin="20 10 20 0">

        <ui:TextBlock
            Margin="0,0,0,6"
            FontSize="22"
            FontTypography="Subtitle"
            Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
            Text="Keybinds Settings" />

        <ui:TextBlock
            Margin="0,0,0,16"
            FontTypography="Caption"
            Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
            Text="Click a hotkey field, then press a new key combination (modifier + key)." />

        <ui:CardControl
            Icon="{ui:SymbolIcon Symbol=Play20}"
            Margin="0,0,0,4"
            Padding="20 10 20 10">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        Text="Play / Pause"
                        TextWrapping="WrapWithOverflow" />
                </StackPanel>
            </ui:CardControl.Header>

            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:TextBox
                    x:Name="PlayPauseHotkeyTextBox"
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    IsReadOnly="True" />

                <ui:Button
                    Grid.Column="1"
                    Click="ResetPlayPauseButton_Click"
                    Content="Reset" />
            </Grid>
        </ui:CardControl>

        <ui:CardControl
            Icon="{ui:SymbolIcon Symbol=Next20}"
            Margin="0,0,0,4"
            Padding="20">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        Text="Next track"
                        TextWrapping="WrapWithOverflow" />
                </StackPanel>
            </ui:CardControl.Header>

            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:TextBox
                    x:Name="NextTrackHotkeyTextBox"
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    IsReadOnly="True" />

                <ui:Button
                    Grid.Column="1"
                    Click="ResetNextTrackButton_Click"
                    Content="Reset" />
            </Grid>
        </ui:CardControl>

        <ui:CardControl
            Icon="{ui:SymbolIcon Symbol=Previous20}"
            Margin="0,0,0,4"
            Padding="20">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        Text="Previous track"
                        TextWrapping="WrapWithOverflow" />
                </StackPanel>
            </ui:CardControl.Header>

            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:TextBox
                    x:Name="PreviousTrackHotkeyTextBox"
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    IsReadOnly="True" />

                <ui:Button
                    Grid.Column="1"
                    Click="ResetPreviousTrackButton_Click"
                    Content="Reset" />
            </Grid>
        </ui:CardControl>

        <ui:CardControl
            Icon="{ui:SymbolIcon Symbol=Window20}"
            Margin="0,0,0,4"
            Padding="20">
            <ui:CardControl.Header>
                <StackPanel>
                    <ui:TextBlock
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        Text="Open flyout"
                        TextWrapping="WrapWithOverflow" />
                </StackPanel>
            </ui:CardControl.Header>

            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:TextBox
                    x:Name="OpenFlyoutHotkeyTextBox"
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    IsReadOnly="True" />

                <ui:Button
                    Grid.Column="1"
                    Click="ResetOpenFlyoutButton_Click"
                    Content="Reset" />
            </Grid>
        </ui:CardControl>

        <ui:TextBlock
            x:Name="HotkeyValidationTextBlock"
            Margin="0,8,0,0"
            FontTypography="Caption"
            Foreground="{ui:ThemeResource SystemFillColorCautionBrush}"
            Visibility="Collapsed" />
    </StackPanel>
</Page>
