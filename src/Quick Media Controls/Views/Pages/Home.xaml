<Page
    x:Class="Quick_Media_Controls.Views.Pages.Home"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Quick_Media_Controls.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Home"
    mc:Ignorable="d">

    <StackPanel Margin="10">
        <ui:Image
            Height="150"
            Margin="0,0,0,10"
            Source="/Assets/banner.jpg"
            CornerRadius="6" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,2,0">
                <ui:CardAction
                    Margin="0,0,0,4"
                    Icon="{ui:SymbolIcon Symbol=AppsAddIn16}"
                    Content="Request a Feature"
                    FontSize="18"
                    Click="CardAction_Click1" />
                <ui:CardAction
                    Margin="0,0,0,0"
                    Icon="{ui:SymbolIcon Symbol=Archive16}"
                    Content="Visit Repository"
                    FontSize="18"
                    Click="CardAction_Click_3" />

            </StackPanel>

            <StackPanel Grid.Column="1" Margin="2,0,0,0">
                <ui:CardAction
                    Margin="0,0,0,4"
                    Icon="{ui:SymbolIcon Symbol=Bug16}"
                    Content="Report a Bug"
                    FontSize="18"
                    Click="CardAction_Click_2" />
                <ui:CardAction
                    Margin="0,0,0,0"
                    Icon="{ui:SymbolIcon Symbol=Heart16}"
                    Content="Sponsor the Project"
                    FontSize="18"
                    Click="CardAction_Click_4" />
            </StackPanel>
        </Grid>
        <ui:InfoBar
            Title="Open Source"
            Margin="0,10,0,0"
            IsClosable="False"
            Visibility="Visible"
            Message="Your support keeps this project alive and growing" />
    </StackPanel>
</Page>
